{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "商媒运营助手",
  "version": "0.1.0",
  "identifier": "com.agentscompany.yunyingagent.desktop",
  "build": {
    "frontendDist": "../desktop-dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": "node ../scripts/prepare-tauri-build.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "商媒运营助手 · 员工工作台",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/.redconvert/**",
            "/tmp/*",
            "/private/tmp/*"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": {
      "../config.json.example": "config.json",
      "../builtin-plugins/": "builtin-plugins/",
      "runtime/bin/": "bin/",
      "runtime/ffmpeg/": "ffmpeg-runtime/",
      "runtime/python/": "python-runtime/",
      "runtime/windows-runtime-manifest.json": "windows-runtime-manifest.json"
    }
  }
}
