# Rust boss backend overrides. Copy to desktop/.env for local development.
BOSS_ACCOUNTING_DB=
BOSS_SERVER_ADDR=127.0.0.1:8787
BOSS_SERVER_URL=http://127.0.0.1:8787
BOSS_ALLOW_REMOTE=0

# Required only when BOSS_SERVER_ADDR is not loopback. Use different random
# values of at least 32 bytes. The employee token can call only employee.*.
BOSS_SERVER_TOKEN=
BOSS_EMPLOYEE_TOKEN=

# Optional Actual Budget integration.
BOSS_ACTUAL_ROOT=../third_party/actual
ACTUAL_CLI_BIN=
ACTUAL_SERVER_URL=
ACTUAL_SYNC_ID=
ACTUAL_PASSWORD=
ACTUAL_TOKEN=
ACTUAL_DEFAULT_ACCOUNT_ID=
ACTUAL_DATA_DIR=
